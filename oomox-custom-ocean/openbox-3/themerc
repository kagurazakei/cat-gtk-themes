# Menu
menu.border.color: #e5dafe

menu.title.bg: Solid Flat
menu.title.bg.color: #1e1e2e
menu.title.bg.shadow: 0
menu.title.text.color: #8affd2
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #1e1e2e
menu.items.text.color: #8affd2
menu.items.disabled.text.color: #6fc6a9

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #92eaff
menu.items.active.text.color: #8affd2

menu.separator.color: #6fc6a9
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #1e1e2e

# Active window
window.active.border.color: #ff687e


window.active.title.bg: flat solid
window.active.title.bg.color: #1e1e2e
window.active.title.separator.color: #1e1e2e
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #8affd2

window.active.handle.bg: flat solid
window.active.handle.bg.color: #1e1e2e

window.active.grip.bg: flat solid
window.active.grip.bg.color: #1e1e2e

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #1e1e2e
window.active.button.unpressed.image.color: #8affd2

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #92eaff
window.active.button.pressed.image.color: #11121d

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #1e1e2e
window.active.button.disabled.image.color: #6fc6a9

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #1e1e2e
window.active.button.hover.image.color: #92eaff

#window.active.button.toggled.bg: #92eaff
#window.active.button.toggled.image.color: #11121d

# Inactive window
window.inactive.border.color: #e2d2fb

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #1e1e2e
window.inactive.title.separator.color: #1e1e2e
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #6fc6a9

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #1e1e2e

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #1e1e2e

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #1e1e2e
window.inactive.button.unpressed.image.color: #6fc6a9

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #92eaff
window.inactive.button.pressed.image.color: #11121d

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #6fc6a9
window.inactive.button.disabled.image.color: #1e1e2e

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #1e1e2e
window.inactive.button.hover.image.color: #92eaff


# OSD
osd.border.width: 1
osd.border.color: #92eaff

osd.bg: flat solid
osd.bg.color: #1e1e2e
osd.label.bg: flat solid
osd.label.bg.color: #1e1e2e
osd.label.text.color: #8affd2

# OSD
osd.bg: Solid Flat
osd.bg.color: #1e1e2e
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #92eaff
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #171726

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #171726
#osd.button.unpressed.*.border.color: #cbbde2

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #92eaff
#osd.button.pressed.*.border.color: #11121d

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #e5dafe
#osd.button.focused.*.border.color: #171726

osd.button.focused.box.color: #92eaff


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 6
padding.width: 8
padding.height: 6
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
